RUNTIME_BACKEND=local
AWS_DEFAULT_REGION=us-east-1

# Required for any path that touches GitHub (reviewer Path A, B, or C).
# A PAT scoped to read/write issues + PRs on the target repo is enough.
GH_TOKEN=

# Required only for reviewer Path B (running the remediation loop locally
# against a Devin org). Leave blank for Path A (dashboard-only) or Path C
# (hosted, driven by GitHub webhooks).
# Generate from https://app.devin.ai under your organization settings.
DEVIN_API_KEY=
DEVIN_ORG_ID=

TARGET_REPO_OWNER=C0smicCrush
TARGET_REPO_NAME=superset-remediation
DEVIN_BYPASS_APPROVAL=false
DEVIN_VERIFICATION_BYPASS_APPROVAL=false
MAX_ACTIVE_REMEDIATIONS=2
LOCAL_INTAKE_PORT=8000
LOCAL_DASHBOARD_PORT=8001
LOCAL_WORKER_POLL_INTERVAL_SECONDS=2
LOCAL_POLLER_INTERVAL_SECONDS=30
LOCAL_STATE_DIR=state
LOCAL_METRICS_DIR=metrics
